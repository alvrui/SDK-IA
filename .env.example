# SDK-IA Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Python Service Configuration (Secretario)
# ============================================================================

# Server settings
SERVER_HOST=127.0.0.1
SERVER_PORT=9000
DEBUG=false

# Mistral API
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_API_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-tiny

# Database
DATABASE_PATH=data/agents.db

# ============================================================================
# Rust Service Configuration (SDK)
# ============================================================================

# Server settings
SDK_IA_SERVER_HOST=127.0.0.1
SDK_IA_SERVER_PORT=9090
SDK_IA_DEBUG=false

# Internal communication
SDK_IA_PYTHON_SERVICE_URL=http://127.0.0.1:9000
SDK_IA_DATABASE_PATH=data/agents.db

# ============================================================================
# UI Configuration
# ============================================================================

UI_PORT=3000
UI_API_BASE=http://localhost:9090

# ============================================================================
# Logging Configuration
# ============================================================================

LOG_LEVEL=info
LOG_FORMAT=json
